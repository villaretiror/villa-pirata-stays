{
    "cleanUrls": false,
    "trailingSlash": false,
    "functions": {
        "api/**/*.ts": {
            "memory": 1024,
            "maxDuration": 10
        }
    },
    "crons": [
        {
            "path": "/api/sync-ical",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/feedback-cron",
            "schedule": "0 10 * * *"
        }
    ],
    "headers": [
        {
            "source": "/api/chat",
            "headers": [
                {
                    "key": "x-vercel-rate-limit",
                    "value": "20"
                },
                {
                    "key": "x-vercel-rate-limit-header",
                    "value": "x-ratelimit-limit"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
                },
                {
                    "key": "Pragma",
                    "value": "no-cache"
                },
                {
                    "key": "Expires",
                    "value": "0"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/contrato",
            "destination": "/index.html"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/|assets/|auth/|.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}
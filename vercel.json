{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "cleanUrls": true,
    "trailingSlash": false,
    "functions": {
        "api/chat.ts": {
            "maxDuration": 45,
            "memory": 1024
        }
    },
    "crons": [
        {
            "path": "/api/sync-ical",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/feedback-cron",
            "schedule": "0 10 * * *"
        }
    ],
    "headers": [
        {
            "source": "/api/chat",
            "headers": [
                {
                    "key": "x-vercel-rate-limit",
                    "value": "20"
                },
                {
                    "key": "x-vercel-rate-limit-header",
                    "value": "x-ratelimit-limit"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
                },
                {
                    "key": "Pragma",
                    "value": "no-cache"
                },
                {
                    "key": "Expires",
                    "value": "0"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/((?!assets/.*|api/.*|.*\\..*|auth/v1/.*).*)",
            "destination": "/index.html"
        }
    ],
    "buildId": "2026-03-12T13:50"
}